        insertEmbeddingAsync:async (embedding: Omit<ConvoNodeEmbedding, "id">, options: Omit<InsertConvoNodeEmbeddingOptions, "permissionFrom"> | undefined): PromiseResultType<ConvoNodeEmbedding> =>{
