                            activeColor:'active',
                            activeBg:'activeBg',
                            activeBorder:'active',
                        },
                        quitButton,
                    ],
                },
                {
                    id:'content',
                    layout:'column',
                    flex:1,
                    border:'muted',
                    bg:'panelAlt',
                    children:[
                        {
                            id:'intro',
                            text:'Use Tab / Shift+Tab to focus, Enter or Space to activate.',
                        },
                        {
                            id:'mouse-note',
                            text:'Mouse clicks are enabled on interactive text. Use the mouse events screen to test release, drag, and wheel.',
                        },
                        nameInput,
                        {
                            id:'set-status',
