import type { ScreenDef } from "../../../../tui/src/tui-types.js";
import { mainLayout } from "./main-layout.js";

export const fileEditorScreen=():ScreenDef=>{
    return mainLayout({
        id:'file-editor',
        layout:'row',
        gap:1,
        padding:1,
        children:[
            {
                id:'file-editor-toolbar',
                layout:'column',
                width:30,
                padding:1,
                gap:1,
                border:'#374151',
                bg:'#0f172a',
                children:[
                    {
                        id:'file-editor-toolbar-title',
                        text:'Files',
                        color:'#93c5fd',
                    },
                    {
                        id:'file-editor-tree-placeholder',
                        layout:'column',
                        gap:1,
                        children:[
                            {
                                id:'file-editor-tree-root',
                                text:'▾ workspace',
                            },
                            {
                                id:'file-editor-tree-file-1',
                                text:'  ○ main.convo',
                            },
                            {
                                id:'file-editor-tree-file-2',
                                text:'  ○ prompts.convo',
                            },
                            {
                                id:'file-editor-tree-file-3',
                                text:'  ○ agents.convo',
                            },
                        ],
                    },
                    {
                        id:'file-editor-actions-title',
                        text:'Actions',
                        color:'#93c5fd',
                    },
                    {
                        id:'file-editor-run-action',
                        text:'Run current file',
                        isButton:true,
                    },
                    {
                        id:'file-editor-save-action',
                        text:'Save file',
                        isButton:true,
                    },
                ],
            },
            {
                id:'file-editor-main',
                layout:'column',
                flex:1,
                padding:1,
                gap:1,
                border:'#374151',
                children:[
                    {
                        id:'file-editor-main-title',
                        text:'Editor',
                        color:'#93c5fd',
                    },
                    {
                        id:'file-editor-editor-placeholder',
                        flex:1,
                        border:'#1f2937',
                        padding:1,
                        text:'Open a .convo file from the tree to edit it here.',
                        color:'#d1d5db',
                    },
                    {
                        id:'file-editor-output-placeholder',
                        height:8,
                        border:'#1f2937',
                        padding:1,
                        text:'Run output will appear here.',
                        color:'#9ca3af',
                    },
                ],
            },
        ],
    })
}
