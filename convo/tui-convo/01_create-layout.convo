<FILE_CONTENT name="main-layout.ts" target-output-path="../../packages/convo-lang-cli/src/lib/tui/main-layout.ts">
``` ts
import type { ScreenDef, SpriteDef } from "../../../../tui/src/tui-types.js";

const screens=[
    {id:'file-editor',label:'File Editor'},
    {id:'db',label:'DB'},
    {id:'api',label:'API'},
    {id:'settings',label:'Settings'},
] as const;

const buttonPadding={left:1,right:1};

const tab=(screenId:string,label:string,activeScreenId:string):SpriteDef=>{

    const active=screenId===activeScreenId;

    return {
        id:`${screenId}-tab`,
        text:label,
        link:screenId,
        isButton:true,
        padding:buttonPadding,
        color:active?'accent-foreground':'sidebar-foreground',
        bg:active?'accent':'sidebar-accent',
        activeColor:'accent-foreground',
        activeBg:'convo-green-muted',
    }
}

const topBar=(activeScreenId:string):SpriteDef=>({
    id:`${activeScreenId}-top-bar`,
    layout:'row',
    height:1,
    gap:1,
    bg:'sidebar',
    children:[
        {
            id:`${activeScreenId}-app-title`,
            text:' Convo-Lang ',
            color:'terminal-green',
            bg:'sidebar',
        },
        ...screens.map(screen=>tab(screen.id,screen.label,activeScreenId)),
    ],
});

const statusBar=(activeScreenId:string):SpriteDef=>({
    id:`${activeScreenId}-status-bar`,
    height:1,
    text:` ${screens.find(screen=>screen.id===activeScreenId)?.label ?? 'Convo-Lang'} | READY | Ctrl+C to exit `,
    color:'terminal-green',
    bg:'sidebar',
});

export const mainLayout=(sprite:SpriteDef):ScreenDef=>{

    const screenId=sprite.id ?? 'main';

    return {
        id:screenId,
        defaultSprite:`${screenId}-tab`,
        root:{
            id:`${screenId}-root`,
            layout:'column',
            color:'foreground',
            bg:'background',
            children:[
                topBar(screenId),
                {
                    id:`${screenId}-body`,
                    layout:'row',
                    flex:1,
                    bg:'background',
                    children:[
                        {
                            ...sprite,
                            id:sprite.id ?? `${screenId}-content`,
                            flex:sprite.flex ?? 1,
                        },
                    ],
                },
                statusBar(screenId),
            ],
        },
    }
}
```
</FILE_CONTENT>

