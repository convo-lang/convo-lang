<FILE_CONTENT name="update.sh" target-output-path="../../packages/brew/update.sh">
``` bash
#!/usr/bin/env bash
set -euo pipefail

# Resolve paths relative to this script so it can be run from any directory.
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/../.." && pwd)"

formula_path="${script_dir}/homebrew-core/Formula/c/convo.rb"
arm_binary="${repo_root}/packages/cli-darwin-arm64/bin/convo"
x64_binary="${repo_root}/packages/cli-darwin-x64/bin/convo"

arm_placeholder="CONVO_DARWIN_ARM64_SHA256"
x64_placeholder="CONVO_DARWIN_X64_SHA256"

sha256_file()
{
    local file_path="$1"

    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "${file_path}" | awk '{print $1}'
    else
        shasum -a 256 "${file_path}" | awk '{print $1}'
    fi
}

require_file()
{
    local file_path="$1"

    if [[ ! -f "${file_path}" ]]; then
        echo "Missing required file: ${file_path}" >&2
        exit 1
    fi
}

# Verify the local binaries and formula exist before calculating replacement values.
require_file "${arm_binary}"
require_file "${x64_binary}"
require_file "${formula_path}"

# Calculate hashes from the local release binaries.
arm_sha256="$(sha256_file "${arm_binary}")"
x64_sha256="$(sha256_file "${x64_binary}")"

# Print manual replacement values for the Homebrew formula.
echo "Replace placeholders in:"
echo "  ${formula_path}"
echo
echo "${arm_placeholder}=${arm_sha256}"
echo "${x64_placeholder}=${x64_sha256}"
echo
echo "Manual replacement commands:"
echo "  perl -0pi -e 's/${arm_placeholder}/${arm_sha256}/g; s/${x64_placeholder}/${x64_sha256}/g' '${formula_path}'"
echo
echo "Formula preview with replacements applied:"
echo

# Show the formula with placeholders replaced, but do not modify the file.
sed \
    -e "s/${arm_placeholder}/${arm_sha256}/g" \
    -e "s/${x64_placeholder}/${x64_sha256}/g" \
    "${formula_path}"
```
