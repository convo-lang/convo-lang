``` bash
#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
homebrew_core_root="$(cd "${repo_root}/../homebrew-core" && pwd)"

package_json="${repo_root}/package.json"
arm_binary="${repo_root}/packages/cli-darwin-arm64/bin/convo"
x64_binary="${repo_root}/packages/cli-darwin-x64/bin/convo"
formula_dir="${homebrew_core_root}/Formula/c"
formula_path="${formula_dir}/convo.rb"

require_file()
{
    local file_path="$1"

    if [[ ! -f "${file_path}" ]]; then
        echo "Missing required file: ${file_path}" >&2
        exit 1
    fi
}

sha256_file()
{
    local file_path="$1"

    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "${file_path}" | awk '{print $1}'
    else
        shasum -a 256 "${file_path}" | awk '{print $1}'
    fi
}

# Verify all required inputs exist before writing the formula.
require_file "${package_json}"
require_file "${arm_binary}"
require_file "${x64_binary}"

# Read the Convo-Lang version from the repository package.json.
version="$(node -e "console.log(require(process.argv[1]).version)" "${package_json}")"

if [[ -z "${version}" ]]; then
    echo "Unable to read version from ${package_json}" >&2
    exit 1
fi

# Calculate SHA256 hashes from the local release binaries.
arm_sha256="$(sha256_file "${arm_binary}")"
x64_sha256="$(sha256_file "${x64_binary}")"

# Ensure the Homebrew formula directory exists in the fork.
mkdir -p "${formula_dir}"

# Write the Homebrew formula directly to the fork.
cat > "${formula_path}" <<EOF
class Convo < Formula
  desc "Convo-Lang CLI"
  homepage "https://github.com/convo-lang/convo-lang/tree/main/packages/cli#readme"
  version "${version}"
  license "MIT"

  depends_on :macos

  on_macos do
    if Hardware::CPU.arm?
      url "https://github.com/convo-lang/convo-lang/releases/download/v${version}/convo-darwin-arm64"
      sha256 "${arm_sha256}"
    else
      url "https://github.com/convo-lang/convo-lang/releases/download/v${version}/convo-darwin-x64"
      sha256 "${x64_sha256}"
    end
  end

  def install
    binary = Hardware::CPU.arm? ? "convo-darwin-arm64" : "convo-darwin-x64"
    chmod 0755, binary
    bin.install binary => "convo"
  end

  test do
    system "#{bin}/convo", "--help"
  end
end
EOF

echo "Updated Homebrew formula:"
echo "  ${formula_path}"
echo
echo "Version: ${version}"
echo "Apple Silicon SHA256: ${arm_sha256}"
echo "Intel SHA256: ${x64_sha256}"
```
