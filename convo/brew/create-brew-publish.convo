<FILE_CONTENT name="convo.rb" target-output-path="../../packages/brew/homebrew-core/Formula/c/convo.rb">
``` ruby
class Convo < Formula
  desc "Convo-Lang CLI"
  homepage "https://github.com/convo-lang/convo-lang/tree/main/packages/cli#readme"
  version "0.9.3"
  license "MIT"

  on_macos do
    if Hardware::CPU.arm?
      url "https://github.com/convo-lang/convo-lang/releases/download/v0.9.3/convo-darwin-arm64"
      sha256 "CONVO_DARWIN_ARM64_SHA256"
    else
      url "https://github.com/convo-lang/convo-lang/releases/download/v0.9.3/convo-darwin-x64"
      sha256 "CONVO_DARWIN_X64_SHA256"
    end
  end

  def install
    binary=Hardware::CPU.arm? ? "convo-darwin-arm64" : "convo-darwin-x64"
    chmod 0755, binary
    bin.install binary => "convo"
  end

  test do
    system "#{bin}/convo", "--help"
  end
end
```
