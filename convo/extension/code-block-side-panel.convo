                    "group": "navigation@01"
                },
                {
                    "command": "convo.text",
                    "when": "resourceLangId == source.convo",
                    "group": "navigation@02"
                },
                {
                    "command": "convo.vars",
                    "when": "resourceLangId == source.convo",
                    "group": "navigation@03"
                },
                {
                    "command": "convo.convert",
                    "when": "resourceLangId == source.convo",
                    "group": "navigation@04"
                },
                {
                    "command": "convo.open-settings",
                    "when": "resourceLangId == source.convo",
                    "group": "navigation@05"
                },
                {
                    "command": "convo.split",
                    "when": "resourceLangId == source.convo",
                    "group": "navigation@06"
                },
                {
                    "command": "convo.complete-graph",
                    "when": "resourceLangId == source.convo",
                    "group": "navigation@07"
                },
                {
                    "command": "convo.flat",
                    "when": "resourceLangId == source.convo",
                    "group": "navigation@08"
                },
                {
                    "command": "convo.flat-all",
                    "when": "resourceLangId == source.convo",
                    "group": "navigation@09"
                },
                {
                    "command": "convo.messages",
                    "when": "resourceLangId == source.convo",
                    "group": "navigation@10"
                },
                {
                    "command": "convo.list-models",
                    "when": "resourceLangId == source.convo",
                    "group": "navigation@11"
                }
            ],
            "view/title": [
                {
                    "command": "convo.refresh-make-targets",
                    "when": "view == convoMakeBuild",
                    "group": "navigation"
                },
                {
                    "command": "convo.code-blocks-refresh",
                    "when": "view == convoCodeBlocks",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "convo.make",
                    "when": "view == convoMakeBuild && viewItem == build",
                    "group": "inline"
                },
                {
                    "command": "convo.make-stop",
                    "when": "view == convoMakeBuild && viewItem == build-active",
                    "group": "inline"
                },
                {
                    "command": "convo.make-open",
                    "when": "view == convoMakeBuild && viewItem =~ /^build/",
                    "group": "inline"
                },
                {
                    "command": "convo.make-delete-all",
                    "when": "view == convoMakeBuild && viewItem =~ /^build/",
                    "group": "inline"
                },
                {
                    "command": "convo.make-sync",
                    "when": "view == convoMakeBuild && viewItem =~ /^build/",
                    "group": "inline"
                },
                {
                    "command": "convo.make-target-open",
                    "when": "view == convoMakeBuild && viewItem =~ /^target-.*-exists/",
                    "group": "inline"
                },
                {
                    "command": "convo.make-target-delete",
                    "when": "view == convoMakeBuild && viewItem =~ /^target-.*-exists.*-preview/",
                    "group": "inline"
                },
                {
                    "command": "convo.make-target-single",
                    "when": "view == convoMakeBuild && viewItem =~ /^target.*-preview/",
                    "group": "inline"
                },
                {
                    "command": "convo.make-target-single-review",
                    "when": "view == convoMakeBuild && viewItem =~ /^target.*-preview/",
                    "group": "inline"
                },
                {
                    "command": "convo.make-target-sync",
                    "when": "view == convoMakeBuild && viewItem =~ /^target-.*-(exists|list).*-preview/",
                    "group": "inline"
                },
                {
                    "command": "convo.make-target-open-convo",
                    "when": "view == convoMakeBuild && viewItem =~ /^target-.*-preview.*-convoExists/",
                    "group": "inline"
                },
                {
                    "command": "convo.code-block-group-apply-all",
                    "when": "view == convoCodeBlocks && viewItem == code-block-group",
                    "group": "inline"
                },
                {
                    "command": "convo.output-tag-open",
                    "when": "view == convoCodeBlocks && viewItem =~ /^code-block-file/",
                    "group": "inline"
                },
                {
                    "command": "convo.output-tag-write",
                    "when": "view == convoCodeBlocks && viewItem =~ /^code-block-file/",
                    "group": "inline"
                },
                {
                    "command": "convo.output-tag-diff",
                    "when": "view == convoCodeBlocks && viewItem =~ /^code-block-file/",
                    "group": "inline"
                },
                {
                    "command": "convo.output-tag-copy",
                    "when": "view == convoCodeBlocks && viewItem =~ /^code-block-file/",
                    "group": "inline"
                },
                {
                    "command": "convo.output-tag-execute-shell",
                    "when": "view == convoCodeBlocks && viewItem =~ /^code-block-shell/",
                    "group": "inline"
                },
                {
                    "command": "convo.output-tag-execute-shell-complete",
                    "when": "view == convoCodeBlocks && viewItem =~ /^code-block-shell/",
                    "group": "inline"
                }
            ]
        },
        "commands": [
            {
                "command": "convo.complete",
                "title": "Convo: Complete - Submits conversation to LLM and append response",
                "shortTitle": "Convo: Complete",
                "icon": "$(play)"
            },
            {
                "command": "convo.complete-graph",
                "title": "Convo: Complete Graph - Runs convo as a node graph",
                "shortTitle": "Convo: Complete Graph",
                "icon": "$(run-all)"
            },
            {
                "command": "convo.refresh-make-targets",
                "title": "Convo: Refresh make targets",
                "icon": "$(refresh)"
            },
            {
                "command": "convo.code-blocks-refresh",
                "title": "Convo: Refresh code blocks",
                "icon": "$(refresh)"
            },
            {
                "command": "convo.code-block-group-apply-all",
                "title": "Convo: Apply All Code Blocks In Message",
                "icon": "$(check-all)"
            },
            {
                "command": "convo.output-tag-open",
                "title": "Convo: Open Output",
                "icon": "$(folder-opened)"
            },
            {
                "command": "convo.output-tag-write",
                "title": "Convo: Write Output",
                "icon": "$(check)"
            },
            {
                "command": "convo.output-tag-diff",
                "title": "Convo: Open Output Diff",
                "icon": "$(diff)"
            },
            {
                "command": "convo.output-tag-copy",
                "title": "Convo: Copy Output",
                "icon": "$(copy)"
            },
            {
                "command": "convo.output-tag-execute-shell",
                "title": "Convo: Run Script",
                "icon": "$(play)"
            },
            {
                "command": "convo.output-tag-execute-shell-complete",
                "title": "Convo: Run Script and Complete",
                "icon": "$(run-all)"
            },
            {
                "command": "convo.parse",
                "title": "Convo: Parse - Parses conversation returning message objects",
                "shortTitle": "Convo: Parse"
            },
            {
                "command": "convo.text",
                "title": "Convo: Flatten - View of conversation with all expressions evaluated",
                "shortTitle": "Convo: Flatten",
                "icon": "$(chrome-restore)"
            },
            {
                "command": "convo.flat",
                "title": "Convo: Flat Message Objects - View of flat conversation as JSON message object. Useful for UI bindings.",
                "shortTitle": "Convo: Flat Message Objects",
                "icon": "$(code-review)"
            },
            {
                "command": "convo.flat-all",
                "title": "Convo: Flat Message Objects All - View of flat conversation as JSON message object with all messages ignoring node processing behavior. Useful for UI bindings.",
                "shortTitle": "Convo: Flat Message Objects",
                "icon": "$(code-review)"
            },
            {
                "command": "convo.messages",
                "title": "Convo: Message Objects - View of conversation as JSON message object. (internal message state).",
                "shortTitle": "Convo: Message Objects",
                "icon": "$(code-review)"
            },
            {
                "command": "convo.vars",
                "title": "Convo: Vars - Evaluates conversation and displaying resulting variables",
                "shortTitle": "Convo: Vars",
                "icon": "$(symbol-misc)"
            },
            {
                "command": "convo.convert",
                "title": "Convo: Convert - Converts the conversation into the native format of the target LLM",
                "shortTitle": "Convo: Convert",
                "icon": "$(json)"
            },
            {
                "command": "convo.split",
                "title": "Convo: Fork - Creates a copy of the conversation and saves it to a new file",
                "shortTitle": "Convo: Fork",
                "icon": "$(repo-forked)"
            },
            {
                "command": "convo.split-complete",
                "title": "Convo: Complete Fork - Creates a fork of the conversation and submits it to the LLM",
                "shortTitle": "Convo: Complete Fork"
            },
            {
                "command": "convo.make-target-open",
                "title": "Convo: Open Make Target",
                "icon": "$(folder-opened)"
            },
            {
                "command": "convo.make-target-single",
                "title": "Convo: Make Single File",
                "icon": "$(play)"
            },
            {
                "command": "convo.make-target-single-review",
                "title": "Convo: Build Review Single File",
                "icon": "$(debug-line-by-line)"
            },
            {
                "command": "convo.make-target-sync",
                "title": "Convo: Sync target with output",
                "icon": "$(check)"
            },
            {
                "command": "convo.make-target-open-convo",
                "title": "Convo: Open target convo",
                "icon": "$(json)"
            },
            {
                "command": "convo.make-target-delete",
                "title": "Convo: Delete Make Target",
                "icon": "$(trash)"
            },
            {
                "command": "convo.make-open",
                "title": "Convo: Make Open",
                "icon": "$(folder-opened)"
            },
            {
                "command": "convo.make-sync",
                "title": "Convo: Make Sync",
                "icon": "$(check-all)"
            },
            {
                "command": "convo.make-delete-all",
                "title": "Convo: Make Delete All - deletes all outputs",
                "icon": "$(trash)"
            },
            {
                "command": "convo.make",
                "title": "Convo: Make - Runs the Convo Make build system",
                "shortTitle": "Convo: Make",
                "icon": "$(run-all)"
            },
            {
                "command": "convo.make-stop",
                "title": "Convo: Make Stop - Stop active make",
                "shortTitle": "Convo: Make Stop",
                "icon": "$(debug-stop)"
            },
            {
                "command": "convo.make-targets",
                "title": "Convo: Make Targets - Parses a convo make file and displays its targets",
                "shortTitle": "Convo: Make Targets",
                "icon": "$(combine)"
            },
            {
                "command": "convo.list-models",
                "title": "Convo: List Models - Lists registered LLM models",
                "shortTitle": "Convo: List Models",
                "icon": "$(list-unordered)"
