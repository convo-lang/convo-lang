        "keybindings": [
            {
                "command": "convo.complete",
                "key": "ctrl+r",
                "mac": "cmd+r",
                "when": "editorTextFocus && editorLangId == 'source.convo'"
            },
            {
                "command": "convo.split-complete",
                "key": "ctrl+shift+r",
                "mac": "cmd+shift+r",
                "when": "editorTextFocus && editorLangId == 'source.convo'"
            },
            {
                "command": "convo.new",
                "key": "shift+alt+ctrl+n",
                "mac": "shift+alt+cmd+n"
            },
            {
                "command": "convo.tab",
                "key": "tab",
                "when": "editorTextFocus && !editorReadonly && editorLangId == 'source.convo'"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Convo-Lang",
            "properties": {
                "convo.defaultModel": {
                    "type": "string",
                    "default": "gpt-4.1",
                    "description": "Default AI model to use for completions",
                    "order": 1
                },
                "convo.openAiBaseUrl": {
                    "type": "string",
                    "default": "https://api.openai.com",
                    "description": "API Base URL to an OpenAI compatible API",
                    "order": 2
                },
                "convo.openAiApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "OpenAI API key for authentication",
                    "order": 3
                },
                "convo.awsBedrockProfile": {
                    "type": "string",
                    "default": "",
                    "description": "AWS Bedrock profile name for authentication",
                    "order": 4
                },
                "convo.awsBedrockApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "AWS Bedrock API key for authentication",
                    "order": 5
                },
                "convo.awsBedrockRegion": {
                    "type": "string",
                    "default": "us-east-1",
                    "description": "AWS region to use with for Bedrock",
                    "order": 6
                },
                "convo.openRouterBaseUrl": {
                    "type": "string",
                    "default": "https://openrouter.ai/api",
                    "description": "API Base URL to OpenRouter",
                    "order": 7
                },
                "convo.openRouterApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "OpenRouter API key for authentication",
                    "order": 8
                },
                "convo.alwaysRunOutputScripts": {
                    "type": "boolean",
                    "default": false,
                    "description": "Always allow runnable shell scripts from convo output blocks to execute without confirmation",
                    "order": 9
                }
            }
