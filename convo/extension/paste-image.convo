<FILE_CONTENT name="register-image-paste-handler.ts" target-output-path="../../packages/convo-lang-tools/lsp/client/src/register-image-paste-handler.ts_" fenced>
```ts
import { DocumentDropOrPasteEditKind, DocumentPasteEdit, DocumentPasteEditProvider, ExtensionContext, languages } from 'vscode';
import { ConvoExt } from './ConvoExt.js';

const imageMimeTypes=[
    'image/png',
    'image/jpeg',
    'image/jpg',
    'image/gif',
    'image/webp',
    'image/svg+xml',
    'image/bmp',
    'image/tiff',
    'image/x-icon',
    'image/heic',
    'image/heif',
    'image/avif',
];

const pastedAltText='pasted image';

export const registerImagePasteHandler=(context:ExtensionContext,ext:ConvoExt)=>
{
    void ext;

    const provider:DocumentPasteEditProvider={
        async provideDocumentPasteEdits(
            document,
            ranges,
            dataTransfer
        ){
            void document;
            void ranges;

            for(const mimeType of imageMimeTypes){
                const item=dataTransfer.get(mimeType);
                if(!item){
                    continue;
                }

                const bytes=await item.asFile()?.data();
                if(!bytes){
                    continue;
                }

                
                const base64=Buffer.from(bytes).toString('base64');
                const text=`![${pastedAltText}](data:${mimeType};base64,${base64})`;

                return [
                    new DocumentPasteEdit(text,'Paste image as markdown data URL',DocumentDropOrPasteEditKind.Text)
                ];
            }

            return;
        }
    };

    context.subscriptions.push(languages.registerDocumentPasteEditProvider(
        [{language:'source.convo',scheme:'file'},'*.convo'],
        provider,
        {
            providedPasteEditKinds: [DocumentDropOrPasteEditKind.Text],
            pasteMimeTypes:imageMimeTypes,
        }
    ));
}

