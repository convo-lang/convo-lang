``` bash
# fail on errors
set -e

# require a vault path argument
if [ -z "$1" ]; then
    echo "Usage: bash install-plugin.sh /path/to/your/obsidian/vault"
    exit 1
fi

# capture the vault path from the first argument
VAULT_PATH="$1"

# define source and target plugin directories
PLUGIN_SRC="packages/obsidian"
PLUGIN_DST="$VAULT_PATH/.obsidian/plugins/convo-lang"

# ensure the source plugin directory exists
if [ ! -d "$PLUGIN_SRC" ]; then
    echo "Plugin source directory not found: $PLUGIN_SRC"
    exit 1
fi

# create the destination plugin directory
mkdir -p "$PLUGIN_DST"

# copy plugin files into the Obsidian vault plugin folder
cp "$PLUGIN_SRC/manifest.json" "$PLUGIN_DST/manifest.json"
cp "$PLUGIN_SRC/main.js" "$PLUGIN_DST/main.js"
cp "$PLUGIN_SRC/styles.css" "$PLUGIN_DST/styles.css"

# optionally copy readme if present
if [ -f "$PLUGIN_SRC/README.md" ]; then
    cp "$PLUGIN_SRC/README.md" "$PLUGIN_DST/README.md"
fi

# report success and next steps
echo "Installed Convo-Lang test plugin to:"
echo "  $PLUGIN_DST"
echo
echo "Next steps:"
echo "1. Open Obsidian"
echo "2. Open Settings -> Community plugins"
echo "3. Disable Restricted mode if needed"
echo "4. Click Reload plugins"
echo "5. Enable Convo-Lang"
```
