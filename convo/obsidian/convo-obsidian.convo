<FILE_CONTENT name="build-plugin.ts" target-output-path="../../packages/obsidian/build-plugin.ts">
``` ts
import {build} from 'bun';

const rootDir=new URL('.',import.meta.url);
const entryPath=new URL('./main.js',rootDir);
const outDir=new URL('./dist/',rootDir);

await build({
    entrypoints:[entryPath.pathname],
    outdir:outDir.pathname,
    target:'browser',
    format:'cjs',
    minify:true,
    sourcemap:'none',
    naming:'main.js',
});

console.log(`Built Obsidian plugin bundle to ${outDir.pathname}`);
```
