/* TypeScript-inspired color scheme for Convo-Lang in Obsidian */

/* Dark theme (VS Code Dark+ palette) */
.theme-dark .cm-s-obsidian .cm-keyword,
.theme-dark .markdown-source-view.mod-cm6 .cm-keyword
{
    color:#569CD6;
}

.theme-dark .cm-s-obsidian .cm-atom,
.theme-dark .markdown-source-view.mod-cm6 .cm-atom
{
    color:#569CD6;
}

.theme-dark .cm-s-obsidian .cm-def,
.theme-dark .markdown-source-view.mod-cm6 .cm-def
{
    color:#DCDCAA;
}

.theme-dark .cm-s-obsidian .cm-variable,
.theme-dark .markdown-source-view.mod-cm6 .cm-variable
{
    color:#9CDCFE;
}

.theme-dark .cm-s-obsidian .cm-variable-2,
.theme-dark .markdown-source-view.mod-cm6 .cm-variable-2
{
    color:#9CDCFE;
