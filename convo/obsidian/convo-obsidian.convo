``` js
'use strict';

const wordBoundary=/[A-Za-z0-9_]/;

const topLevelKeywords=new Set([
    'do',
    'thinkingResult',
    'result',
    'define',
    'debug',
    'end',
    'target',
    'make',
    'stage',
    'app',
    'parallelEnd',
    'parallel',
    'insertEnd',
    'agentEnd',
    'queue',
    'flush',
    'insert',
    'nop',
    'templateEnd',
    'template',
]);

const specialContentRoles=new Set([
    'nodeEnd',
    'node',
    'goto',
    'exitGraph',
]);

const routeRoles=new Set([
    'exit',
    'to',
    'from',
]);

const functionModifiers=new Set([
    'agent',
    'public',
    'local',
]);

const systemFunctions=new Set([
    'elif',
    'if',
    'else',
    'while',
    'break',
    'foreach',
    'for',
    'in',
    'do',
    'outInline',
    'outTrim',
    'out',
    'then',
    'fn',
    'return',
    'case',
    'default',
    'switch',
    'test',
]);

const operatorFunctions=new Set([
    'lt',
    'lte',
    'neq',
    'eq',
    'gt',
    'gte',
    'is',
    'add',
    'sub',
    'mul',
    'div',
    'not',
    'mod',
    'pow',
    'inc',
    'dec',
    'no',
]);

const logicFunctions=new Set([
    'and',
    'or',
]);

const typeFunctions=new Set([
    'enum',
    'struct',
    'array',
]);

const typeKeywords=new Set([
    'string',
    'number',
    'int',
    'boolean',
    'time',
    'void',
    'any',
    'map',
    'array',
    'object',
]);

const constValues=new Set([
    'true',
    'false',
    'null',
    'undefined',
    'convo',
    '__args',
    '__return',
    '__error',
    '__debug',
    '__disableAutoComplete',
    '__file',
    '__cwd',
]);

const conditionTags=new Set([
    '@condition',
    '@disabled',
    '@taskName',
    '@taskDescription',
]);

const typeTags=new Set([
    '@json',
    '@inputConversation',
    '@inputType',
]);

function isWordChar(ch)
{
    return !!ch && wordBoundary.test(ch);
}

function readWord(stream)
{
    let value='';
    while(!stream.eol() && isWordChar(stream.peek())){
        value+=stream.next();
    }
    return value;
}

function readUntilSpace(stream)
{
    let value='';
    while(!stream.eol()){
        const ch=stream.peek();
        if(ch===undefined || /\s/.test(ch)){
            break;
        }
        value+=stream.next();
    }
    return value;
}

function skipSpaces(stream)
{
    while(!stream.eol() && /\s/.test(stream.peek())){
        stream.next();
    }
}

function tokenString(stream,state,quote)
{
    let escaped=false;
    while(!stream.eol()){
        const ch=stream.next();
        if(escaped){
            escaped=false;
            continue;
        }
        if(ch==='\\'){
            escaped=true;
            continue;
        }
        if(ch===quote){
            state.mode=null;
            break;
        }
    }
    return 'string';
}

function tokenInlineCode(stream,state)
{
    while(!stream.eol()){
        const ch=stream.next();
        if(ch==='`'){
            state.mode=null;
            break;
        }
    }
    return 'quote';
}

function tokenBlock(stream,state)
{
    if(state.mode==='dq'){
        return tokenString(stream,state,'"');
    }
    if(state.mode==='sq'){
        return tokenString(stream,state,"'");
    }
    if(state.mode==='inline'){
        return tokenInlineCode(stream,state);
    }
    if(state.mode==='heredoc'){
        if(stream.match(/-{3,}/)){
            state.mode=null;
            return 'comment';
        }
        stream.skipToEnd();
        return null;
    }
    return null;
}

function tokenLineStart(stream,state)
{
    if(stream.match(/\s*#.*/)){
        return 'comment';
    }
    if(stream.match(/\s*\/\/.*/)){
        return 'comment';
    }

    const pos=stream.pos;
    skipSpaces(stream);

    if(stream.peek()==='>'){
        stream.next();
        state.afterGt=true;
        state.lastTag=null;
        return 'keyword';
    }

    if(stream.peek()==='@'){
        stream.next();
        const tag='@'+readWord(stream);
        state.lastTag=tag;
        if(conditionTags.has(tag) || typeTags.has(tag) || tag==='@routeTo' || tag==='@routeFrom'){
            return 'keyword';
        }
        if(tag==='@exit' || tag==='@to' || tag==='@from' || tag==='@import' || tag==='@name'){
            return 'keyword';
        }
        return 'atom';
    }

    stream.pos=pos;
    return null;
}

function tokenAfterGt(stream,state)
{
    skipSpaces(stream);
    if(stream.eol()){
        state.afterGt=false;
        return null;
    }

    const start=stream.pos;
    const word=readWord(stream);

    if(!word){
        stream.next();
        state.afterGt=false;
        return null;
    }

    state.afterGt=false;

    if(word==='thinking'){
        return 'def';
    }

    if(specialContentRoles.has(word) || topLevelKeywords.has(word)){
        return 'keyword';
    }

    if(routeRoles.has(word)){
        return 'def';
    }

    if(functionModifiers.has(word)){
        return 'keyword';
    }

    const save=stream.pos;
    skipSpaces(stream);
    const nextWord=readWord(stream);
    skipSpaces(stream);
    if(nextWord && stream.peek()==='('){
        stream.pos=start+word.length;
        return 'keyword';
    }
    stream.pos=save;

    return 'atom';
}

function tokenTagValue(stream,state)
{
    if(stream.sol()){
        state.lastTag=null;
        return null;
    }

    if(state.lastTag==='@import'){
        const value=readUntilSpace(stream);
        if(!value){
            stream.next();
            return null;
        }
        return 'string';
    }

    if(state.lastTag==='@name'){
        const value=readUntilSpace(stream);
        if(!value){
            stream.next();
            return null;
        }
        return 'variableName';
    }

    if(state.lastTag==='@routeTo' || state.lastTag==='@routeFrom'){
        const value=readUntilSpace(stream);
        if(!value){
            stream.next();
            return null;
        }
        return 'variableName';
    }

    return null;
}

function tokenBase(stream,state)
{
    if(stream.sol()){
        const lineStartToken=tokenLineStart(stream,state);
        if(lineStartToken){
            return lineStartToken;
        }
    }

    const blockToken=tokenBlock(stream,state);
    if(blockToken){
        return blockToken;
    }

    if(state.afterGt){
        return tokenAfterGt(stream,state);
    }

    skipSpaces(stream);
    if(stream.eol()){
        state.lastTag=null;
        return null;
    }

    const tagValueToken=tokenTagValue(stream,state);
    if(tagValueToken){
        return tagValueToken;
    }

    if(stream.match('${')){
        return 'keyword';
    }

    if(stream.match('\{{') || stream.match('}}')){
        return 'bracket';
    }

    if(stream.match('->')){
        return 'operator';
    }

    if(stream.match('<<')){
        return 'operator';
    }

    if(stream.match(/-{3,}/)){
        state.mode='heredoc';
        return 'comment';
    }

    if(stream.match('???') || stream.match('===')){
        return 'string';
    }

    const ch=stream.peek();

    if(ch==='"'){
        stream.next();
        state.mode='dq';
        return 'string';
    }

    if(ch==="'"){
        stream.next();
        state.mode='sq';
        return 'string';
    }

    if(ch==='`'){
        stream.next();
        state.mode='inline';
        return 'quote';
    }

    if(ch==='<' || ch==='>' || ch==='=' || ch==='!' || ch===':' || ch===',' || ch==='(' || ch===')' || ch==='[' || ch===']'){
        stream.next();
        return 'operator';
    }

    if(/[0-9]/.test(ch) || (ch==='-' && /[0-9]/.test(stream.string.charAt(stream.pos+1)))){
        stream.match(/-?(\d+\.\d+|\.\d+|\d+)/);
        return 'number';
    }

    if(ch==='$'){
        const value=readUntilSpace(stream);
        if(value==='$$RAG$$' || value==='$$CONTENT$$' || value==='$$CHILD$$' || value==='$$CHILDREN$$' || /^\$\$SLOT_\w+\$\$$/.test(value)){
            return 'keyword';
        }
        return 'operator';
    }

    if(/[A-Za-z_]/.test(ch)){
        const word=readWord(stream);

        if(typeKeywords.has(word)){
            return 'typeName';
        }

        if(constValues.has(word)){
            return 'atom';
        }

        if(systemFunctions.has(word)){
            return stream.peek()==='('?'keyword':'variableName';
        }

        if(operatorFunctions.has(word) || logicFunctions.has(word)){
            return stream.peek()==='('?'operator':'variableName';
        }

        if(typeFunctions.has(word)){
            return stream.peek()==='('?'typeName':'variableName';
        }

        if(/^[A-Z]\w*$/.test(word)){
            return 'typeName';
        }

        if(stream.peek()===':'){
            return 'propertyName';
        }

        if(stream.peek()==='('){
            return 'variableName';
        }

        return 'variableName';
    }

    stream.next();
    return null;
}

function createConvoMode()
{
    return {
        startState()
        {
            return {
                mode:null,
                afterGt:false,
                lastTag:null,
            };
        },
        token(stream,state)
        {
            return tokenBase(stream,state);
        }
    };
}

function registerConvoLanguage(plugin)
{
    const cm=window.CodeMirror;
    if(!cm || !cm.defineMode){
        console.warn('Convo-Lang: CodeMirror not available');
        return;
    }

    if(!cm.modes.convo){
        cm.defineMode('convo',createConvoMode);
    }

    if(cm.defineMIME){
        cm.defineMIME('text/x-convo','convo');
    }

    plugin.registerMarkdownCodeBlockProcessor('convo',()=>{});
    plugin.registerExtensions(['convo'],'convo');
}

module.exports=class ConvoLangPlugin extends obsidian.Plugin
{
    async onload()
    {
        registerConvoLanguage(this);
    }
};
