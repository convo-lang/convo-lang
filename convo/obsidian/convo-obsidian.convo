'use strict';

const wordBoundary=/[A-Za-z0-9_]/;

const topLevelKeywords=new Set([
    'do',
    'thinkingResult',
    'result',
    'define',
    'debug',
    'end',
    'target',
    'make',
    'stage',
    'app',
