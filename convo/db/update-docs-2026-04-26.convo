+        if(!r.success){
+            return r;
+        }
+        const data=r.result?.data;
+        if(!data){
+            return {
+                success:false,
+                error:'Called function did not return a value',
+                statusCode:500,
+            }
+        }
+
+        return {
+            success:true,
+            result:data as T,
+        }
+    }
