+const hasConvoPathWildcard=(path:string):boolean=>{
+    return path.includes('*');
+}
+
+const ensureTrailingSlash=(path:string):string=>{
+    return path.endsWith('/')?path:`${path}/`;
+}
+
+const getMountPointRoot=(mountPoint:string):string=>{
+    return mountPoint==='/'?'/':mountPoint.substring(0,mountPoint.length-1);
+}
+
+const getConvoPathLiteralPrefix=(path:string):string=>{
+    const i=path.indexOf('*');
+    if(i===-1){
+        return ensureTrailingSlash(path);
+    }
+
+    const slash=path.lastIndexOf('/',i);
+    if(slash<0){
+        return '/';
+    }
+
+    const prefix=path.substring(0,slash+1);
+    return prefix || '/';
+}
+
+const getConvoPathSegments=(path:string):string[]=>{
+    if(path==='/'){
+        return [];
+    }
+
+    const start=path.startsWith('/')?1:0;
+    const end=path.endsWith('/')?path.length-1:path.length;
+    const p=path.substring(start,end);
+
+    return p?p.split('/'):[];
+}
+
+const escapeRegex=(value:string):string=>{
+    return value.replace(/[|\\{}()[\]^$+?.]/g,'\\$&');
+}
+
+const pathSegmentMatchesConvoGlob=(pattern:string,segment:string):boolean=>{
+    if(pattern==='*'){
+        return true;
+    }
+
+    if(!pattern.includes('*')){
+        return pattern===segment;
+    }
+
+    const regex=new RegExp(`^${pattern.split('*').map(escapeRegex).join('[^/]*')}$`);
+    return regex.test(segment);
+}
+
+const pathMatchesConvoGlob=(pattern:string,path:string):boolean=>{
+    if(!hasConvoPathWildcard(pattern)){
+        return pattern===path;
+    }
+
+    const patternSegments=getConvoPathSegments(pattern);
+    const pathSegments=getConvoPathSegments(path);
+
+    const match=(patternIndex:number,pathIndex:number):boolean=>{
+        if(patternIndex===patternSegments.length){
+            return pathIndex===pathSegments.length;
+        }
+
+        const segment=patternSegments[patternIndex];
+        if(segment==='**'){
+            if(patternIndex===patternSegments.length-1){
+                return true;
+            }
+
+            for(let i=pathIndex;i<=pathSegments.length;i++){
+                if(match(patternIndex+1,i)){
+                    return true;
+                }
+            }
+            return false;
+        }
+
+        if(pathIndex>=pathSegments.length){
+            return false;
+        }
+
+        return pathSegmentMatchesConvoGlob(segment!,pathSegments[pathIndex]!)?
+            match(patternIndex+1,pathIndex+1)
+        :
+            false;
+    }
+
+    return match(0,0);
+}
