+    private _doesPathMatchStepPath(nodePath:string,stepPath:string):boolean{
+        const normalizedNodePath=this._normalizeQueryPath(nodePath);
+        const normalizedStepPath=this._normalizeQueryPath(stepPath);
+        if(normalizedNodePath===undefined || normalizedStepPath===undefined){
+            return false;
+        }
+        return this._doPathSegmentsMatch(
+            this._getPathSegments(normalizedNodePath),
+            this._getPathSegments(normalizedStepPath),
+            0,
+            0
+        );
+    }
+
+    private _normalizeQueryPath(queryPath:string):string|undefined{
+        let normalized=queryPath.replace(/\/+/g,'/');
+        if(!normalized.startsWith('/')){
+            normalized=`/${normalized}`;
+        }
+        if(normalized.length>1 && normalized.endsWith('/')){
+            normalized=normalized.slice(0,-1);
+        }
+        const segments=this._getPathSegments(normalized);
+        if(segments.some(segment=>segment==='.' || segment==='..')){
+            return undefined;
+        }
+        return normalized;
+    }
+
+    private _getPathSegments(normalizedPath:string):string[]{
+        return normalizedPath==='/'?[]:normalizedPath.slice(1).split('/');
+    }
+
+    private _doPathSegmentsMatch(pathSegments:string[],stepSegments:string[],pathIndex:number,stepIndex:number):boolean{
+        if(stepIndex===stepSegments.length){
+            return pathIndex===pathSegments.length;
+        }
+
+        const stepSegment=stepSegments[stepIndex];
+        if(stepSegment==='**'){
+            if(stepIndex===stepSegments.length-1){
+                return true;
+            }
+            for(let i=pathIndex;i<=pathSegments.length;i++){
+                if(this._doPathSegmentsMatch(pathSegments,stepSegments,i,stepIndex+1)){
+                    return true;
+                }
+            }
+            return false;
+        }
+
+        return (
+            pathIndex<pathSegments.length &&
+            this._doesPathSegmentMatch(pathSegments[pathIndex],stepSegment) &&
+            this._doPathSegmentsMatch(pathSegments,stepSegments,pathIndex+1,stepIndex+1)
+        );
+    }
+
+    private _doesPathSegmentMatch(pathSegment:string,stepSegment:string):boolean{
+        if(!stepSegment.includes('*')){
+            return pathSegment===stepSegment;
+        }
+        const pattern=`^${stepSegment.split('*').map(segment=>this._escapeRegex(segment)).join('.*')}$`;
+        return new RegExp(pattern).test(pathSegment);
+    }
+
+    private _escapeRegex(value:string):string{
+        return value.replace(/[.*+?^${}()|[\]\\]/g,'\\$&');
+    }
+
