+/**
+ * Creates a matcher for ConvoDb query path glob patterns.
+ *
+ * Query path glob rules:
+ * - `*` matches zero or more characters within one path segment
+ * - `**` matches zero or more complete path segments
+ * - matching is case-sensitive and against the full normalized node path
+ *
+ * @param path Query path or literal node path.
+ */
+const createConvoNodePathMatcher=(path:string):(nodePath:string)=>boolean=>{
+    const p=normalizeConvoNodeQueryPath(path);
+    if(!p){
+        return ()=>false;
+    }
+    if(hasConvoNodePathWildcard(p)){
+        return nodePath=>isConvoNodePathGlobMatch(nodePath,p);
+    }
+    return nodePath=>nodePath===p;
+}
+
+/**
+ * Normalizes a query path. Literal paths use normal node path normalization. Glob paths allow
+ * `*` and `**` while still normalizing duplicate slashes and rejecting `.` / `..` segments.
+ *
+ * @param path Query path.
+ */
+const normalizeConvoNodeQueryPath=(path:string):string|undefined=>(
+    hasConvoNodePathWildcard(path)?
+        normalizeConvoNodePathGlob(path)
+    :
+        normalizeConvoNodePath(path,'none')
+);
+
+/**
+ * Normalizes a ConvoDb query path glob.
+ *
+ * @param path Query path glob.
+ */
+const normalizeConvoNodePathGlob=(path:string):string|undefined=>{
+    if(!path){
+        return undefined;
+    }
+    const parts=path.split('/').filter(p=>p.length);
+    for(const part of parts){
+        if(part==='.' || part==='..' || (part.includes('**') && part!=='**')){
+            return undefined;
+        }
+    }
+    return '/'+parts.join('/');
+}
+
+/**
+ * Returns true if the path contains a wildcard token.
+ *
+ * @param path Path to test.
+ */
+const hasConvoNodePathWildcard=(path:string):boolean=>path.includes('*');
+
+
+/**
+ * Returns true if a normalized node path matches a query path glob.
+ *
+ * @param path Normalized node path.
+ * @param glob Query path glob.
+ */
+const isConvoNodePathGlobMatch=(path:string,glob:string):boolean=>{
+    const p=normalizeConvoNodePath(path,'none');
+    const g=normalizeConvoNodeQueryPath(glob);
+    if(!p || !g){
+        return false;
+    }
+    if(!hasConvoNodePathWildcard(g)){
+        return p===g;
+    }
+
+    const pathSegments=getConvoNodePathSegments(p);
+    const globSegments=getConvoNodePathSegments(g);
+    const memo:Record<string,boolean>={};
+
+    const match=(pathIndex:number,globIndex:number):boolean=>{
+        const memoKey=`${pathIndex}:${globIndex}`;
+        if(memoKey in memo){
+            return memo[memoKey]??false;
+        }
+
+        const globSegment=globSegments[globIndex];
+        let result=false;
+
+        if(globSegment===undefined){
+            result=pathIndex===pathSegments.length;
+        }else if(globSegment==='**'){
+            for(let i=pathIndex;i<=pathSegments.length;i++){
+                if(match(i,globIndex+1)){
+                    result=true;
+                    break;
+                }
+            }
+        }else if(pathIndex<pathSegments.length && isConvoNodePathSegmentGlobMatch(pathSegments[pathIndex]??'',globSegment)){
+            result=match(pathIndex+1,globIndex+1);
+        }
+
+        memo[memoKey]=result;
+        return result;
+    }
+
+    return match(0,0);
+}
+
+/**
+ * Splits a normalized node path into path segments.
+ *
+ * @param path Normalized node path.
+ */
+const getConvoNodePathSegments=(path:string):string[]=>path==='/'?[]:path.substring(1).split('/');
+
+/**
+ * Returns true if a single path segment matches a segment glob.
+ *
+ * @param segment Path segment.
+ * @param glob Segment glob.
+ */
+const isConvoNodePathSegmentGlobMatch=(segment:string,glob:string):boolean=>{
+    if(glob.includes('**')){
+        return false;
+    }
+    let pattern='^';
+    for(let i=0;i<glob.length;i++){
+        const c=glob[i];
+        pattern+=c==='*'?'[^/]*':escapeRegex(c??'');
+    }
+    pattern+='$';
+    return new RegExp(pattern).test(segment);
+}
+
+/**
+ * Escapes regex metacharacters in a string.
+ *
+ * @param value Value to escape.
+ */
+const escapeRegex=(value:string):string=>value.replace(/[.*+?^${}()|[\]\\]/g,'\\$&');
+
 /**
  * Parses a serialized query traversal token into traversal state.
  *
