+const normalizeConvoPathGlob=(path:string):ResultType<string>=>{
+    let normalized=path.replace(/\/+/g,'/');
+    if(normalized.length>1 && normalized.endsWith('/')){
+        normalized=normalized.substring(0,normalized.length-1);
+    }
+    if(!normalized){
+        normalized='/';
+    }
+
+    const parts=splitNormalizedPathSegments(normalized);
+    if(parts.some(p=>p==='.' || p==='..')){
+        return {
+            success:false,
+            error:`Invalid query path. "." and ".." path segments are not allowed - ${path}`,
+            statusCode:400,
+        };
+    }
+    if(parts.some(p=>p.includes('**') && p!=='**')){
+        return {
+            success:false,
+            error:`Invalid query path. "**" wildcard must be a complete path segment - ${path}`,
+            statusCode:400,
+        };
+    }
+
+    return {
+        success:true,
+        result:normalized,
+    };
+}
+
+const splitNormalizedPathSegments=(path:string):string[]=>{
+    if(path==='/' || !path){
+        return [];
+    }
+    return path.replace(/^\/+/,'').split('/').filter(Boolean);
+}
+
+const createPathGlobMatcher=(glob:string):(path:string)=>boolean=>{
+    const patternSegments=splitNormalizedPathSegments(glob);
+    const segmentMatchers=patternSegments.map(s=>s==='**'?null:createSegmentGlobMatcher(s));
+
+    return (path:string)=>{
+        const pathSegments=splitNormalizedPathSegments(path);
+        const memo=new Set<string>();
+
+        const match=(patternIndex:number,pathIndex:number):boolean=>{
+            const key=`${patternIndex}:${pathIndex}`;
+            if(memo.has(key)){
+                return false;
+            }
+
+            if(patternIndex>=patternSegments.length){
+                return pathIndex>=pathSegments.length;
+            }
+
+            const patternSegment=patternSegments[patternIndex];
+            if(patternSegment==='**'){
+                if(patternIndex===patternSegments.length-1){
+                    return true;
+                }
+                for(let i=pathIndex;i<=pathSegments.length;i++){
+                    if(match(patternIndex+1,i)){
+                        return true;
+                    }
+                }
+                memo.add(key);
+                return false;
+            }
+
+            if(pathIndex>=pathSegments.length){
+                memo.add(key);
+                return false;
+            }
+
+            const matcher=segmentMatchers[patternIndex];
+            if(!matcher?.test(pathSegments[pathIndex]!)){
+                memo.add(key);
+                return false;
+            }
+
+            const matched=match(patternIndex+1,pathIndex+1);
+            if(!matched){
+                memo.add(key);
+            }
+            return matched;
+        }
+
+        return match(0,0);
+    }
+}
+
+const createSegmentGlobMatcher=(glob:string):RegExp=>{
+    let pattern='^';
+    for(const ch of glob){
+        pattern+=ch==='*'?'[^/]*':escapeRegExp(ch);
+    }
+    pattern+='$';
+    return new RegExp(pattern);
+}
+
+const appendPathGlobCandidateFilter=(where:string[],bind:any[],glob:string,columnName:string)=>{
+    const firstWildcard=glob.indexOf('*');
+    if(firstWildcard<0){
+        where.push(`${columnName} = ?`);
+        bind.push(glob);
+        return;
+    }
+
+    const prefix=glob.substring(0,firstWildcard);
+    if(!prefix || prefix==='/'){
+        return;
+    }
+
+    if(prefix.endsWith('/')){
+        const base=prefix.substring(0,prefix.length-1) || '/';
+        if(base==='/'){
+            return;
+        }
+
+        where.push(`(${columnName} = ? OR ${columnName} LIKE ? ESCAPE '\\')`);
+        bind.push(base,`${escapeSqlLikeLiteral(prefix)}%`);
+    }else{
+        where.push(`${columnName} LIKE ? ESCAPE '\\'`);
+        bind.push(`${escapeSqlLikeLiteral(prefix)}%`);
+    }
+}
+
+const escapeRegExp=(value:string)=>{
+    return value.replace(/[.*+?^${}()|[\]\\]/g,'\\$&');
+}
+
+const escapeSqlLikeLiteral=(value:string)=>{
+    return value.replace(/\\/g,'\\\\').replace(/%/g,'\\%').replace(/_/g,'\\_');
+}
+
 const buildNodeOrderByClause=(orderBy:ConvoNodeOrderBy[],alias='')=>{
     if(!orderBy.length){
         return '';
