{
    "compilerOptions": {
        "rootDir": ".",
        "sourceMap": true,
        "declaration": true,
        "moduleResolution": "nodenext",
        "jsx": "react-jsx",
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "forceConsistentCasingInFileNames": true,
        "noPropertyAccessFromIndexSignature": true,
        "noImplicitReturns": true,
        "noImplicitOverride": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedIndexedAccess": true,
        "preserveSymlinks": true,
        "strict": true,
        "importHelpers": true,
        "target": "es2020",
        "module": "nodenext",
        "lib": [
            "es2020",
            "dom"
        ],
        "types": [
            "node","bun"
        ],
        "baseUrl": ".",
        "ignoreDeprecations": "6.0",
        "skipLibCheck": true,
        "skipDefaultLibCheck": true,
        "esModuleInterop": true,
        "outDir": "./dist",
        "composite": true,
        "paths": {
            "@convo-lang/convo-crawler": [
                "./packages/convo-crawler/src/index.ts"
            ],
            "@convo-lang/convo-lang": [
                "./packages/convo-lang/src/index.ts"
            ],
            "@convo-lang/convo-lang-api-routes": [
                "./packages/convo-lang-api-routes/src/index.ts"
            ],
            "@convo-lang/convo-lang-aws-cdk": [
                "./packages/convo-lang-aws-cdk/src/index.ts"
            ],
            "@convo-lang/convo-lang-bedrock": [
                "./packages/convo-lang-bedrock/src/index.ts"
            ],
            "@convo-lang/convo-lang-browser": [
                "./packages/convo-lang-browser/src/index.ts"
            ],
            "@convo-lang/convo-lang-cli": [
                "./packages/convo-lang-cli/src/index.ts"
            ],
            "@convo-lang/convo-lang-doc-query": [
                "./packages/convo-lang-doc-query/src/index.ts"
            ],
            "@convo-lang/convo-lang-make": [
                "./packages/convo-lang-make/src/index.ts"
            ],
            "@convo-lang/convo-lang-mcp-client": [
                "./packages/convo-lang-mcp-client/src/index.ts"
            ],
            "@convo-lang/convo-lang-pdf": [
                "./packages/convo-lang-pdf/src/index.ts"
            ],
            "@convo-lang/convo-lang-pinecone": [
                "./packages/convo-lang-pinecone/src/index.ts"
            ],
            "@convo-lang/convo-lang-react": [
                "./packages/convo-lang-react/src/index.ts"
            ],
            "@convo-lang/hono/*": [
                "./packages/hono/src/*"
            ],
            "@convo-lang/db/*": [
                "./packages/db/src/*"
            ]
        }
    },
    "exclude": [
        "node_modules",
        "tmp"
    ]
}
